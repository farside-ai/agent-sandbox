# Copy to `.env` and edit:  cp .env.example .env

# REQUIRED. Absolute path to the project you open in Zed.
# The sandbox mounts this path at the SAME location inside the container so the
# agents' working directory matches what Zed sends them. Must be an absolute path.
WORKSPACE_DIR=/Users/you/path/to/your/project

# ---------------------------------------------------------------------------
# Authentication — Option A: API keys (simplest, works headless).
# Fill in keys for the agents you use. Leave blank to instead log in
# interactively inside the container (Option B; see README "Authentication").
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Codex accepts a dedicated key; OPENAI_API_KEY also works.
CODEX_API_KEY=
