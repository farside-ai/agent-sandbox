// Native Windows Zed variant for Podman installed inside WSL Ubuntu.
// Zed launches wsl.exe, which runs podman inside the Ubuntu distribution.
//
// Merge into Zed's actual settings.json (`agent: open settings`).
// Change "Ubuntu" below if `wsl.exe --list --quiet` shows a different name.
// Prerequisite: the container must be running in WSL (`make RUNTIME=podman up`).
{
  "agent_servers": {
    "Claude (sandbox)": {
      "type": "custom",
      "command": "wsl.exe",
      "args": [
        "-d",
        "Ubuntu",
        "--",
        "podman",
        "exec",
        "-i",
        "agent-sandbox",
        "claude-agent-acp"
      ],
      "env": {}
    },
    "Codex (sandbox)": {
      "type": "custom",
      "command": "wsl.exe",
      "args": [
        "-d",
        "Ubuntu",
        "--",
        "podman",
        "exec",
        "-i",
        "agent-sandbox",
        "codex-acp"
      ],
      "env": {}
    }
  }
}
